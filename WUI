			local palDrag, satDrag = false, false

			palette.InputBegan:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
					palDrag = true
				end
			end)
			satBar.InputBegan:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
					satDrag = true
				end
			end)

			trackConnection(UserInputService.InputChanged:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
					local mousePos = getMousePosition()
					if palDrag then
						local relX = math.clamp((mousePos.X - palette.AbsolutePosition.X) / palette.AbsoluteSize.X, 0, 1)
						local relY = math.clamp((mousePos.Y - palette.AbsolutePosition.Y) / palette.AbsoluteSize.Y, 0, 1)
						h = relX
						s = 1 - relY
						palInd.Position = UDim2.new(relX, -5, relY, -5)
						updateColor()
					elseif satDrag then
						local relY = math.clamp((mousePos.Y - satBar.AbsolutePosition.Y) / satBar.AbsoluteSize.Y, 0, 1)
						v = 1 - relY
						satInd.Position = UDim2.new(0, -3, relY, -2)
						updateColor()
					end
				end
			end))

			trackConnection(UserInputService.InputEnded:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
					palDrag = false
					satDrag = false
				end
			end))

			local api = {}
			function api:Set(color)
				color = typeof(color) == "Color3" and color or Color3.new(1, 1, 1)
				h, s, v = Color3.toHSV(color)
				palInd.Position = UDim2.new(h, -5, 1 - s, -5)
				satInd.Position = UDim2.new(0, -3, 1 - v, -2)
				updateColor()
			end
			function api:Get()
				return Color3.fromHSV(h, s, v)
			end
			return api, cpFrame
		end

