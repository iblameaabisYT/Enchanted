		local resizing = false

		resizer.InputBegan:Connect(function(input)
			if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch) and opt.can_resize then
				resizing = true
				input.Changed:Connect(function()
					if input.UserInputState == Enum.UserInputState.End then
						resizing = false
					end
				end)
			end
		end)

		trackConnection(RunService.Heartbeat:Connect(function()
			if resizing then
				local mousePos = getMousePosition()
				local newX = math.max(opt.min_size.X, mousePos.X - windowFrame.AbsolutePosition.X + 8)
