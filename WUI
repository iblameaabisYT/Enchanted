local Library = {}

function Library:AddWindow(title, options)
	windowCount = windowCount + 1
	local currentWindowIndex = windowCount

	title = tostring(title or "Window")
	options = typeof(options) == "table" and options or {}

	local opt = {
		tween_time = options.tween_time or 0.25,
		min_size = options.min_size or a.min_size,
		can_resize = options.can_resize ~= nil and options.can_resize or a.can_resize,
		main_color = options.main_color or a.main_color,
		title_bar = options.title_bar or { a.main_color },
		title_bar_transparency = options.title_bar_transparency or 0,
		background = options.background or { Color3.fromRGB(22, 24, 28) },
		background_transparency = options.background_transparency or 0,
	}

	if typeof(opt.title_bar) == "Color3" then
		opt.title_bar = { opt.title_bar }
	end
	if typeof(opt.background) == "Color3" then
		opt.background = { opt.background }
	end

	local baseZ = currentWindowIndex * 10

	local windowFrame = Instance.new("ImageLabel")
	windowFrame.Name = "Window_" .. title
	windowFrame.Active = true
	windowFrame.Selectable = true
	windowFrame.BackgroundTransparency = 1
	windowFrame.ClipsDescendants = true
	windowFrame.Position = UDim2.new(0, 30 + (currentWindowIndex - 1) * 40, 0, 30 + (currentWindowIndex - 1) * 30)
	windowFrame.Size = UDim2.new(0, opt.min_size.X, 0, opt.min_size.Y)
	windowFrame.Image = "rbxassetid://2851926732"
	windowFrame.ImageColor3 = opt.background[1]
	windowFrame.ImageTransparency = opt.background_transparency
	windowFrame.ScaleType = Enum.ScaleType.Slice
