		tabTextLabel.TextColor3 = Color3.fromRGB(130, 135, 160)
		tabTextLabel.TextSize = 12
		tabTextLabel.TextXAlignment = Enum.TextXAlignment.Left
		tabTextLabel.ZIndex = baseZ + 5
		tabTextLabel.Parent = tabBtnFrame

		local tabPage = Instance.new("Frame")
		tabPage.Name = "Page_" .. tabName
		tabPage.BackgroundTransparency = 1
		tabPage.Size = UDim2.new(1, 0, 1, 0)
		tabPage.Visible = false
		tabPage.ZIndex = baseZ + 3
		tabPage.Parent = contentArea

		local pageScroller = Instance.new("ScrollingFrame")
		pageScroller.Name = "Scroller"
		pageScroller.BackgroundTransparency = 1
		pageScroller.BorderSizePixel = 0
		pageScroller.Size = UDim2.new(1, 0, 1, 0)
		pageScroller.CanvasSize = UDim2.new(0, 0, 0, 0)
		pageScroller.ScrollBarThickness = 3
		pageScroller.ScrollBarImageColor3 = opt.accent
		pageScroller.ScrollBarImageTransparency = 0.4
		pageScroller.ZIndex = baseZ + 3
		pageScroller.AutomaticCanvasSize = Enum.AutomaticSize.Y
		pageScroller.Parent = tabPage

		local pageLayout = Instance.new("UIListLayout")
		pageLayout.SortOrder = Enum.SortOrder.LayoutOrder
		pageLayout.Padding = UDim.new(0, 6)
		pageLayout.Parent = pageScroller
		Utility.createPadding(pageScroller, 14, 14, 16, 16)

		local TabAPI = createElementsInContainer(pageScroller, 0)

		local function selectTab()
			if activeTabBtn and activeTabBtn ~= tabBtnFrame then
				Utility.tween(activeTabBtn, {BackgroundTransparency = 1, BackgroundColor3 = Color3.fromRGB(88, 101, 242)}, 0.22)
				local prevAccent = activeTabBtn:FindFirstChild("Accent")
				if prevAccent then Utility.tween(prevAccent, {BackgroundTransparency = 1}, 0.22) end
				local prevContainer = activeTabBtn:FindFirstChildOfClass("Frame")
				if prevContainer then
					Utility.tween(prevContainer, {BackgroundTransparency = 0.85}, 0.22)
					local prevImg = prevContainer:FindFirstChildOfClass("ImageLabel")
					if prevImg then Utility.tween(prevImg, {ImageColor3 = Color3.fromRGB(100, 105, 130)}, 0.22) end
				end
				for _, lbl in ipairs(activeTabBtn:GetChildren()) do
					if lbl:IsA("TextLabel") then
						Utility.tween(lbl, {TextColor3 = Color3.fromRGB(130, 135, 160)}, 0.22)
					end
				end
			end

			for _, page in ipairs(contentArea:GetChildren()) do
				if page:IsA("Frame") then page.Visible = false end
			end

			activeTabBtn = tabBtnFrame
			activeTabPage = tabPage

			Utility.tween(tabBtnFrame, {BackgroundTransparency = 0.88, BackgroundColor3 = opt.accent}, 0.22)
			Utility.tween(tabAccent, {BackgroundTransparency = 0}, 0.22)
			Utility.tween(tabIconContainer, {BackgroundTransparency = 0.7}, 0.22)
			Utility.tween(tabIconImg, {ImageColor3 = opt.accent}, 0.22)
			Utility.tween(tabTextLabel, {TextColor3 = Color3.fromRGB(235, 238, 252)}, 0.22)

			tabPage.Visible = true
			breadcrumbLabel.Text = title .. "  ›  " .. tabName
		end

		tabBtnFrame.MouseButton1Click:Connect(selectTab)

		tabBtnFrame.MouseEnter:Connect(function()
			if tabBtnFrame ~= activeTabBtn then
				Utility.tween(tabBtnFrame, {BackgroundTransparency = 0.93}, 0.15)
				Utility.tween(tabTextLabel, {TextColor3 = Color3.fromRGB(190, 195, 218)}, 0.15)
			end
		end)
		tabBtnFrame.MouseLeave:Connect(function()
			if tabBtnFrame ~= activeTabBtn then
				Utility.tween(tabBtnFrame, {BackgroundTransparency = 1}, 0.15)
				Utility.tween(tabTextLabel, {TextColor3 = Color3.fromRGB(130, 135, 160)}, 0.15)
			end
		end)

		function TabAPI:Show()
			selectTab()
		end

		local tabCount = 0
		for _, c in ipairs(tabHolder:GetChildren()) do
			if c:IsA("TextButton") then tabCount = tabCount + 1 end
		end
		if tabCount <= 1 then
			task.defer(selectTab)
		end

		return TabAPI, tabPage
	end

	if blurEffect then
		Utility.tween(blurEffect, {Size = 8}, 0.55)
	end

	return WindowAPI, mainFrame
end

return Library
