					sliderDragging = true
				end
			end)

			UserInputService.InputChanged:Connect(function(input)
				if sliderDragging and input.UserInputType == Enum.UserInputType.MouseMovement then
					local mousePos = getMousePosition()
					local percent = (mousePos.X - sliderTrack.AbsolutePosition.X) / sliderTrack.AbsoluteSize.X
					setSliderValue(percent)
				end
			end)

			UserInputService.InputEnded:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 then
					if sliderDragging then
						sliderDragging = false
						local mousePos = getMousePosition()
						local percent = math.clamp((mousePos.X - sliderTrack.AbsolutePosition.X) / sliderTrack.AbsoluteSize.X, 0, 1)
						setSliderValue(percent)
					end
				end
			end)

			local api = {}
			function api:Set(value)
				value = tonumber(value) or sliderOptions.min
				value = math.clamp(value, sliderOptions.min, sliderOptions.max)
				local percent = (value - sliderOptions.min) / math.max(1, sliderOptions.max - sliderOptions.min)
				setSliderValue(percent)
			end
			function api:Get()
				return tonumber(valueLabel.Text) or sliderOptions.min
			end
			return api, sliderFrame
		end

