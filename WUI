			sliderKnob.Parent = sliderFill
			sliderKnob.AnchorPoint = Vector2.new(0, 0.5)

			createShadow(sliderKnob, 3)

			local function setSliderValue(percent)
				percent = math.clamp(percent, 0, 1)
				local range = sliderOptions.max - sliderOptions.min
				local value = math.floor(sliderOptions.min + range * percent)
				valueLabel.Text = tostring(value)
				tween(sliderFill, { Size = UDim2.new(percent, 0, 1, 0) }, 0.05)
				pcall(callback, value)
			end

			local defaultPercent = (sliderOptions.default - sliderOptions.min) / math.max(1, sliderOptions.max - sliderOptions.min)
			setSliderValue(defaultPercent)

