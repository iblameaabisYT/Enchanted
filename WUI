				sTitle.TextSize = 12
				sTitle.TextXAlignment = Enum.TextXAlignment.Left
				sTitle.ZIndex = baseZ + 4
				sTitle.Parent = sf

				local sValue = Instance.new("TextLabel")
				sValue.BackgroundTransparency = 1
				sValue.Position = UDim2.new(0.7, 0, 0, 0)
				sValue.Size = UDim2.new(0.3, 0, 0, 18)
				sValue.Font = Enum.Font.GothamBold
				sValue.Text = tostring(sliderOpts.default)
				sValue.TextColor3 = Color3.fromRGB(240, 242, 250)
				sValue.TextSize = 12
				sValue.TextXAlignment = Enum.TextXAlignment.Right
				sValue.ZIndex = baseZ + 4
				sValue.Parent = sf

				local sTrack = createRoundFrame({
					Color = Color3.fromRGB(40, 44, 52),
					Size = UDim2.new(1, 0, 0, 6),
					Position = UDim2.new(0, 0, 0, 26),
					CornerRadius = 3,
				})
				sTrack.ZIndex = baseZ + 4
				sTrack.ClipsDescendants = true
				sTrack.Parent = sf

				local sFill = createRoundFrame({
					Color = opt.main_color,
					Size = UDim2.new(0, 0, 1, 0),
					CornerRadius = 3,
				})
				sFill.ZIndex = baseZ + 5
				sFill.Parent = sTrack

				local function setVal(pct)
					pct = math.clamp(pct, 0, 1)
					local val = math.floor(sliderOpts.min + (sliderOpts.max - sliderOpts.min) * pct)
					sValue.Text = tostring(val)
					tween(sFill, { Size = UDim2.new(pct, 0, 1, 0) }, 0.05)
					pcall(cb, val)
				end

				local defPct = (sliderOpts.default - sliderOpts.min) / math.max(1, sliderOpts.max - sliderOpts.min)
				setVal(defPct)

				local dragging = false
				local clickRegion = Instance.new("TextButton")
				clickRegion.BackgroundTransparency = 1
				clickRegion.Size = UDim2.new(1, 0, 0, 16)
				clickRegion.Position = UDim2.new(0, 0, 0, 22)
				clickRegion.Text = ""
				clickRegion.ZIndex = baseZ + 6
				clickRegion.Parent = sf

				clickRegion.InputBegan:Connect(function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1 then
						dragging = true
					end
				end)

				UserInputService.InputChanged:Connect(function(input)
					if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
						local mp = getMousePosition()
						local pct = (mp.X - sTrack.AbsolutePosition.X) / sTrack.AbsoluteSize.X
						setVal(pct)
					end
				end)

				UserInputService.InputEnded:Connect(function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1 then
						dragging = false
					end
				end)

				if isExpanded then updateFolderSize() end
				local api = {}
				function api:Set(val)
					val = math.clamp(tonumber(val) or sliderOpts.min, sliderOpts.min, sliderOpts.max)
					local pct = (val - sliderOpts.min) / math.max(1, sliderOpts.max - sliderOpts.min)
					setVal(pct)
				end
				return api, sf
			end

			return FolderAPI, folderFrame
		end

