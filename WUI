				bf.BackgroundColor3 = opt.accent
				bf.BackgroundTransparency = 0.15
				bf.BorderSizePixel = 0
				bf.Size = UDim2.new(0, 10, 0, 36)
				bf.ZIndex = baseZ + 5 + nestLevel
				bf.ClipsDescendants = true
				bf.Parent = haFrame
				Utility.createCorner(bf, 8)

				local btn = Instance.new("TextButton")
				btn.BackgroundTransparency = 1
				btn.Size = UDim2.new(1, 0, 1, 0)
				btn.Font = Enum.Font.GothamSemibold
				btn.Text = btnText
				btn.TextColor3 = Color3.fromRGB(245, 247, 255)
				btn.TextSize = 12
				btn.ZIndex = baseZ + 6 + nestLevel
				btn.AutoButtonColor = false
				btn.Parent = bf

				task.defer(function()
					if btn and btn.Parent then bf.Size = UDim2.new(0, btn.TextBounds.X + 28, 0, 36) end
				end)

				btn.MouseButton1Click:Connect(function() Utility.ripple(bf, Mouse.X, Mouse.Y); pcall(cb) end)
				btn.MouseEnter:Connect(function() Utility.tween(bf, {BackgroundTransparency = 0}, 0.15) end)
				btn.MouseLeave:Connect(function() Utility.tween(bf, {BackgroundTransparency = 0.15}, 0.15) end)

				return bf
			end
			return HorizAPI, haFrame
		end

		return ElementAPI
	end

