						s = 1 - relY
						paletteIndicator.Position = UDim2.new(relX, -4, relY, -4)
						updateColor()
					elseif satDragging then
						local relY = math.clamp((mousePos.Y - satBar.AbsolutePosition.Y) / satBar.AbsoluteSize.Y, 0, 1)
						v = 1 - relY
						satIndicator.Position = UDim2.new(0, -2, relY, -1)
