			local fClickBtn = Instance.new("TextButton")
			fClickBtn.BackgroundTransparency = 1
			fClickBtn.Size = UDim2.new(1, 0, 1, 0)
			fClickBtn.Text = ""
			fClickBtn.ZIndex = baseZ + 7 + nestLevel
			fClickBtn.Parent = folderHeader

			local fContent = Instance.new("Frame")
			fContent.BackgroundTransparency = 1
			fContent.Position = UDim2.new(0, 10, 0, 42)
			fContent.Size = UDim2.new(1, -20, 0, 0)
			fContent.Visible = false
			fContent.ZIndex = baseZ + 4 + nestLevel
			fContent.Parent = folderOuter

			local fLayout = Instance.new("UIListLayout")
			fLayout.SortOrder = Enum.SortOrder.LayoutOrder
			fLayout.Padding = UDim.new(0, 6)
			fLayout.Parent = fContent

			local isExpanded = false

			local function updateSize()
				if isExpanded then
					local ch = fLayout.AbsoluteContentSize.Y
					fContent.Size = UDim2.new(1, -20, 0, ch)
					folderOuter.Size = UDim2.new(1, 0, 0, 42 + ch + 10)
				else
					folderOuter.Size = UDim2.new(1, 0, 0, 38)
				end
			end

			fLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
				if isExpanded then updateSize() end
			end)

			fClickBtn.MouseButton1Click:Connect(function()
				isExpanded = not isExpanded
				if isExpanded then
					Utility.tween(fArrow, {Rotation = 90, TextColor3 = opt.accent}, opt.tween_time)
					fContent.Visible = true
					updateSize()
				else
					Utility.tween(fArrow, {Rotation = 0}, opt.tween_time)
					fContent.Visible = false
					folderOuter.Size = UDim2.new(1, 0, 0, 38)
				end
			end)

			fClickBtn.MouseEnter:Connect(function()
				Utility.tween(folderHeader, {BackgroundColor3 = Color3.fromRGB(22, 24, 34)}, 0.15)
			end)
			fClickBtn.MouseLeave:Connect(function()
				Utility.tween(folderHeader, {BackgroundColor3 = Color3.fromRGB(18, 20, 28)}, 0.15)
			end)

			return createElementsInContainer(fContent, nestLevel + 1), folderOuter
		end

