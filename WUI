local function shadow(parent, depth, trans)
	depth = depth or 12; trans = trans or 0.6
	local h = newFrame({
		BackgroundTransparency = 1,
		Position = UDim2.new(0,-depth,0,-depth),
		Size     = UDim2.new(1,depth*2,1,depth*2),
		ZIndex   = math.max(1,(parent.ZIndex or 1)-1),
		Name     = "__shadow",
	})
	h.Parent = parent
	local img = Instance.new("ImageLabel")
	img.BackgroundTransparency = 1
	img.Size              = UDim2.new(1,0,1,0)
	img.Image             = "rbxassetid://5554236805"
	img.ImageColor3       = Color3.new(0,0,0)
	img.ImageTransparency = trans
	img.ScaleType         = Enum.ScaleType.Slice
	img.SliceCenter       = Rect.new(23,23,277,277)
	img.ZIndex            = h.ZIndex
	img.Parent            = h
	return h
end

local function ripple(btn, mx, my)
	task.spawn(function()
		if not btn or not btn.Parent then return end
		local r = newFrame({
			BackgroundColor3    = Color3.new(1,1,1),
			BackgroundTransparency = 0.8,
			ZIndex              = btn.ZIndex + 20,
			AnchorPoint         = Vector2.new(0.5,0.5),
			Position            = UDim2.new(0, mx - btn.AbsolutePosition.X,
			                                0, my - btn.AbsolutePosition.Y),
			Size                = UDim2.new(0,0,0,0),
		})
		corner(r, 999)
		r.Parent = btn
		local ms = math.max(btn.AbsoluteSize.X, btn.AbsoluteSize.Y) * 2.4
		tw(r, {Size=UDim2.new(0,ms,0,ms), BackgroundTransparency=1}, 0.55)
		task.wait(0.55)
		if r and r.Parent then r:Destroy() end
	end)
end

