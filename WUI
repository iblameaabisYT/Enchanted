			folderArrow.Size = UDim2.new(0, 18, 1, 0)
			folderArrow.Font = Enum.Font.GothamBold
			folderArrow.Text = "▸"
			folderArrow.TextColor3 = Color3.fromRGB(225, 228, 240)
			folderArrow.TextSize = 12
			folderArrow.ZIndex = baseZ + 5 + nestLevel
			folderArrow.Parent = folderHeader

			local folderTitle = Instance.new("TextLabel")
			folderTitle.BackgroundTransparency = 1
			folderTitle.Position = UDim2.new(0, 30, 0, 0)
			folderTitle.Size = UDim2.new(1, -38, 1, 0)
			folderTitle.Font = Enum.Font.GothamSemibold
			folderTitle.Text = folderName
			folderTitle.TextColor3 = Color3.fromRGB(240, 242, 252)
			folderTitle.TextSize = 13
			folderTitle.TextXAlignment = Enum.TextXAlignment.Left
			folderTitle.ZIndex = baseZ + 5 + nestLevel
			folderTitle.Parent = folderHeader

			local folderClickBtn = Instance.new("TextButton")
			folderClickBtn.BackgroundTransparency = 1
			folderClickBtn.Size = UDim2.new(1, 0, 1, 0)
			folderClickBtn.Text = ""
			folderClickBtn.ZIndex = baseZ + 6 + nestLevel
			folderClickBtn.Parent = folderHeader

			local folderContent = Instance.new("Frame")
			folderContent.Name = "Content"
			folderContent.BackgroundTransparency = 1
			folderContent.Position = UDim2.new(0, 10, 0, 38)
			folderContent.Size = UDim2.new(1, -20, 0, 0)
			folderContent.Visible = false
			folderContent.ZIndex = baseZ + 3 + nestLevel
			folderContent.Parent = folderOuter

			local contentLayout = Instance.new("UIListLayout")
			contentLayout.SortOrder = Enum.SortOrder.LayoutOrder
			contentLayout.Padding = UDim.new(0, 6)
			contentLayout.Parent = folderContent

			local isExpanded = false

			local function updateFolderSize()
				if isExpanded then
					local contentHeight = contentLayout.AbsoluteContentSize.Y
					folderContent.Size = UDim2.new(1, -20, 0, contentHeight)
					folderOuter.Size = UDim2.new(1, 0, 0, 38 + contentHeight + 8)
				else
					folderOuter.Size = UDim2.new(1, 0, 0, 34)
				end
			end

			contentLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
				if isExpanded then
					updateFolderSize()
				end
			end)

			folderClickBtn.MouseButton1Click:Connect(function()
				isExpanded = not isExpanded
				if isExpanded then
					tween(folderArrow, {Rotation = 90}, opt.tween_time)
					folderContent.Visible = true
					updateFolderSize()
				else
					tween(folderArrow, {Rotation = 0}, opt.tween_time)
					folderContent.Visible = false
					folderOuter.Size = UDim2.new(1, 0, 0, 34)
				end
			end)

			folderClickBtn.MouseEnter:Connect(function()
				tween(folderHeader, {BackgroundTransparency = 0.2}, 0.15)
			end)
			folderClickBtn.MouseLeave:Connect(function()
				tween(folderHeader, {BackgroundTransparency = 0.4}, 0.15)
			end)

			local FolderAPI = createElementsInContainer(folderContent, parentPage, nestLevel + 1)
			return FolderAPI, folderOuter
		end

		function ElementAPI:AddHorizontalAlignment()
			local haFrame = Instance.new("Frame")
			haFrame.Name = "HorizontalAlignment"
			haFrame.BackgroundTransparency = 1
			haFrame.Size = UDim2.new(1, 0, 0, 34)
			haFrame.ZIndex = baseZ + 3 + nestLevel
			haFrame.Parent = parentScroller

			local haLayout = Instance.new("UIListLayout")
			haLayout.FillDirection = Enum.FillDirection.Horizontal
			haLayout.SortOrder = Enum.SortOrder.LayoutOrder
			haLayout.VerticalAlignment = Enum.VerticalAlignment.Center
			haLayout.Padding = UDim.new(0, 6)
			haLayout.Parent = haFrame

			local HorizAPI = {}

			function HorizAPI:AddButton(btnText, cb)
				btnText = tostring(btnText or "Button")
				cb = typeof(cb) == "function" and cb or function() end

				local btnFrame = Instance.new("Frame")
				btnFrame.BackgroundColor3 = opt.main_color
				btnFrame.BackgroundTransparency = 0.2
				btnFrame.BorderSizePixel = 0
				btnFrame.Size = UDim2.new(0, 10, 0, 32)
				btnFrame.ZIndex = baseZ + 4 + nestLevel
				btnFrame.ClipsDescendants = true
				btnFrame.Parent = haFrame
				createCorner(btnFrame, 7)

				local btn = Instance.new("TextButton")
				btn.BackgroundTransparency = 1
				btn.Size = UDim2.new(1, 0, 1, 0)
				btn.Font = Enum.Font.GothamSemibold
				btn.Text = btnText
				btn.TextColor3 = Color3.fromRGB(245, 247, 255)
				btn.TextSize = 12
				btn.ZIndex = baseZ + 5 + nestLevel
				btn.AutoButtonColor = false
				btn.Parent = btnFrame

				task.defer(function()
					if btn and btn.Parent then
						btnFrame.Size = UDim2.new(0, btn.TextBounds.X + 28, 0, 32)
					end
				end)

				btn.MouseButton1Click:Connect(function()
					rippleEffect(btnFrame, Mouse.X, Mouse.Y)
					pcall(cb)
				end)
				btn.MouseEnter:Connect(function()
					tween(btnFrame, {BackgroundTransparency = 0.05}, 0.15)
				end)
				btn.MouseLeave:Connect(function()
					tween(btnFrame, {BackgroundTransparency = 0.2}, 0.15)
				end)

				return btnFrame
			end

			return HorizAPI, haFrame
		end

		return ElementAPI
	end

	function WindowAPI:AddTab(tabName)
		tabName = tostring(tabName or "Tab")
		tabSelectionBar.Visible = true

		local tabBtn = Instance.new("TextButton")
		tabBtn.Name = "Tab_" .. tabName
		tabBtn.BackgroundColor3 = Color3.fromRGB(38, 40, 48)
		tabBtn.BackgroundTransparency = 1
		tabBtn.BorderSizePixel = 0
		tabBtn.Size = UDim2.new(0, 10, 0, 26)
		tabBtn.AutoButtonColor = false
		tabBtn.Font = Enum.Font.GothamSemibold
		tabBtn.Text = tabName
		tabBtn.TextColor3 = Color3.fromRGB(155, 158, 170)
		tabBtn.TextSize = 12
		tabBtn.ZIndex = baseZ + 5
		tabBtn.Parent = tabButtonsHolder
		createCorner(tabBtn, 6)
		createPadding(tabBtn, 0, 0, 14, 14)

		task.defer(function()
			if tabBtn and tabBtn.Parent then
				tabBtn.Size = UDim2.new(0, tabBtn.TextBounds.X + 32, 0, 26)
				updateTabButtonsWidth()
			end
		end)

		local tabPage = Instance.new("Frame")
		tabPage.Name = "Page_" .. tabName
		tabPage.BackgroundTransparency = 1
		tabPage.Size = UDim2.new(1, 0, 1, 0)
		tabPage.Visible = false
		tabPage.ZIndex = baseZ + 2
		tabPage.Parent = tabContainer

		local pageScroller = Instance.new("ScrollingFrame")
		pageScroller.Name = "Scroller"
		pageScroller.BackgroundTransparency = 1
		pageScroller.BorderSizePixel = 0
		pageScroller.Size = UDim2.new(1, 0, 1, 0)
		pageScroller.CanvasSize = UDim2.new(0, 0, 0, 0)
		pageScroller.ScrollBarThickness = 3
		pageScroller.ScrollBarImageColor3 = opt.main_color
		pageScroller.ScrollBarImageTransparency = 0.35
		pageScroller.ZIndex = baseZ + 2
		pageScroller.AutomaticCanvasSize = Enum.AutomaticSize.Y
		pageScroller.Parent = tabPage

		local pageLayout = Instance.new("UIListLayout")
		pageLayout.SortOrder = Enum.SortOrder.LayoutOrder
		pageLayout.Padding = UDim.new(0, 6)
		pageLayout.Parent = pageScroller

		createPadding(pageScroller, 4, 10, 0, 0)

		local TabAPI = createElementsInContainer(pageScroller, tabPage, 0)

		local function selectTab()
			if dropdownOpen then
				return
			end

			if activeTabButton and activeTabButton ~= tabBtn then
				tween(activeTabButton, {TextColor3 = Color3.fromRGB(155, 158, 170), BackgroundTransparency = 1}, 0.2)
			end

			for _, page in ipairs(tabContainer:GetChildren()) do
				if page:IsA("Frame") then
					page.Visible = false
				end
			end

			activeTab = tabPage
			activeTabButton = tabBtn

			tween(tabBtn, {TextColor3 = Color3.fromRGB(255, 255, 255), BackgroundTransparency = 0.82}, 0.2)
			tabPage.Visible = true

			task.defer(function()
				moveHighlight(tabBtn)
			end)
		end

		tabBtn.MouseButton1Click:Connect(selectTab)
		tabBtn.MouseEnter:Connect(function()
			if tabBtn ~= activeTabButton then
				tween(tabBtn, {TextColor3 = Color3.fromRGB(210, 212, 225), BackgroundTransparency = 0.88}, 0.15)
			end
		end)
		tabBtn.MouseLeave:Connect(function()
			if tabBtn ~= activeTabButton then
				tween(tabBtn, {TextColor3 = Color3.fromRGB(155, 158, 170), BackgroundTransparency = 1}, 0.15)
			end
		end)

		function TabAPI:Show()
			selectTab()
		end

		local tabCount = 0
		for _, child in ipairs(tabButtonsHolder:GetChildren()) do
			if child:IsA("TextButton") then
				tabCount = tabCount + 1
			end
		end
		if tabCount <= 1 then
			task.defer(selectTab)
		end

		return TabAPI, tabPage
	end

	return WindowAPI, windowFrame
end

return Library
