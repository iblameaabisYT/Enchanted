		function ElementAPI:AddFolder(folderName)
			folderName = tostring(folderName or "Folder")

			local folderOuter = Instance.new("Frame")
			folderOuter.Name = "Folder_" .. folderName
			folderOuter.BackgroundTransparency = 1
			folderOuter.Size = UDim2.new(1, 0, 0, 34)
			folderOuter.ClipsDescendants = false
			folderOuter.ZIndex = baseZ + 3 + nestLevel
			folderOuter.Parent = parentScroller

			local folderHeader = Instance.new("Frame")
			folderHeader.Name = "Header"
			folderHeader.BackgroundColor3 = opt.main_color
			folderHeader.BackgroundTransparency = 0.4
			folderHeader.BorderSizePixel = 0
			folderHeader.Size = UDim2.new(1, 0, 0, 34)
			folderHeader.ZIndex = baseZ + 4 + nestLevel
			folderHeader.Parent = folderOuter
			createCorner(folderHeader, 8)
			createStroke(folderHeader, opt.main_color, 1, 0.5)

			local folderArrow = Instance.new("TextLabel")
			folderArrow.BackgroundTransparency = 1
