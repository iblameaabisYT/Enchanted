	windowFrame.ZIndex = baseZ
	windowFrame.Parent = WindowsHolder

	local windowCorner = Instance.new("UICorner")
	windowCorner.CornerRadius = UDim.new(0, 10)
	windowCorner.Parent = windowFrame

	createShadow(windowFrame, 10)

	local windowStroke = createStroke(windowFrame, Color3.fromRGB(50, 54, 62), 1.5, 0.3)

	local titleBar = Instance.new("Frame")
	titleBar.Name = "TitleBar"
	titleBar.BackgroundColor3 = opt.title_bar[1]
	titleBar.BackgroundTransparency = opt.title_bar_transparency
	titleBar.BorderSizePixel = 0
	titleBar.Size = UDim2.new(1, 0, 0, 36)
	titleBar.ZIndex = baseZ + 2
	titleBar.Parent = windowFrame

	local barCorner = Instance.new("UICorner")
	barCorner.CornerRadius = UDim.new(0, 10)
	barCorner.Parent = titleBar

	local barBottomCover = Instance.new("Frame")
	barBottomCover.Name = "BottomCover"
	barBottomCover.BackgroundColor3 = opt.title_bar[1]
	barBottomCover.BackgroundTransparency = opt.title_bar_transparency
	barBottomCover.BorderSizePixel = 0
	barBottomCover.Position = UDim2.new(0, 0, 1, -10)
	barBottomCover.Size = UDim2.new(1, 0, 0, 10)
	barBottomCover.ZIndex = baseZ + 1
	barBottomCover.Parent = titleBar

	if #opt.title_bar > 1 then
		local gradient = Instance.new("UIGradient")
		gradient.Rotation = 90
		local keypoints = {}
		if #opt.title_bar == 2 then
			keypoints = {
				ColorSequenceKeypoint.new(0, opt.title_bar[1]),
				ColorSequenceKeypoint.new(1, opt.title_bar[2]),
			}
		else
			keypoints = {
				ColorSequenceKeypoint.new(0, opt.title_bar[1]),
				ColorSequenceKeypoint.new(0.5, opt.title_bar[2]),
				ColorSequenceKeypoint.new(1, opt.title_bar[3]),
			}
		end
		gradient.Color = ColorSequence.new(keypoints)
		gradient.Parent = titleBar
		titleBar.BackgroundColor3 = Color3.new(1, 1, 1)
		barBottomCover.BackgroundColor3 = opt.title_bar[#opt.title_bar]
	end

	local toggleBtn = Instance.new("ImageButton")
	toggleBtn.Name = "ToggleBtn"
	toggleBtn.BackgroundTransparency = 1
	toggleBtn.Position = UDim2.new(0, 8, 0, 7)
	toggleBtn.Size = UDim2.new(0, 22, 0, 22)
	toggleBtn.ZIndex = baseZ + 5
	toggleBtn.Image = "rbxassetid://95488535511703"
	toggleBtn.ImageColor3 = Color3.fromRGB(220, 225, 235)
	toggleBtn.Parent = titleBar

	local titleLabel = Instance.new("TextLabel")
	titleLabel.Name = "Title"
	titleLabel.BackgroundTransparency = 1
	titleLabel.Position = UDim2.new(0, 36, 0, 0)
	titleLabel.Size = UDim2.new(1, -44, 1, 0)
	titleLabel.Font = Enum.Font.GothamBold
	titleLabel.Text = title
	titleLabel.TextColor3 = Color3.fromRGB(240, 242, 248)
	titleLabel.TextSize = 15
	titleLabel.TextXAlignment = Enum.TextXAlignment.Left
	titleLabel.ZIndex = baseZ + 4
	titleLabel.Parent = titleBar

	local closeBtn = Instance.new("TextButton")
	closeBtn.Name = "CloseBtn"
	closeBtn.BackgroundTransparency = 1
	closeBtn.Position = UDim2.new(1, -32, 0, 6)
	closeBtn.Size = UDim2.new(0, 24, 0, 24)
	closeBtn.Font = Enum.Font.GothamBold
	closeBtn.Text = "×"
	closeBtn.TextColor3 = Color3.fromRGB(180, 180, 190)
	closeBtn.TextSize = 20
	closeBtn.ZIndex = baseZ + 5
	closeBtn.Parent = titleBar

	closeBtn.MouseEnter:Connect(function()
		tween(closeBtn, { TextColor3 = Color3.fromRGB(255, 80, 80) }, 0.15)
	end)
	closeBtn.MouseLeave:Connect(function()
		tween(closeBtn, { TextColor3 = Color3.fromRGB(180, 180, 190) }, 0.15)
	end)
	closeBtn.MouseButton1Click:Connect(function()
		tween(windowFrame, { ImageTransparency = 1, Size = UDim2.new(0, opt.min_size.X - 20, 0, opt.min_size.Y - 20) }, 0.3)
		task.wait(0.3)
		windowFrame.Visible = false
	end)

	local tabSelectionBar = createRoundFrame({
		Color = Color3.fromRGB(18, 20, 24),
		Transparency = 0.3,
		Size = UDim2.new(1, -24, 0, 32),
		Position = UDim2.new(0, 12, 0, 40),
		CornerRadius = 8,
		Parent = windowFrame,
	})
	tabSelectionBar.Name = "TabSelection"
	tabSelectionBar.ZIndex = baseZ + 2
	tabSelectionBar.Visible = false
	tabSelectionBar.ClipsDescendants = true

	createStroke(tabSelectionBar, Color3.fromRGB(40, 44, 52), 1, 0.6)

	local tabScroller = Instance.new("ScrollingFrame")
	tabScroller.Name = "TabScroller"
	tabScroller.BackgroundTransparency = 1
	tabScroller.BorderSizePixel = 0
	tabScroller.Size = UDim2.new(1, -8, 1, -4)
	tabScroller.Position = UDim2.new(0, 4, 0, 2)
	tabScroller.CanvasSize = UDim2.new(0, 0, 1, 0)
	tabScroller.ScrollBarThickness = 0
	tabScroller.ScrollingDirection = Enum.ScrollingDirection.X
	tabScroller.ZIndex = baseZ + 3
	tabScroller.Parent = tabSelectionBar

	local tabButtonsHolder = Instance.new("Frame")
	tabButtonsHolder.Name = "TabButtons"
	tabButtonsHolder.BackgroundTransparency = 1
	tabButtonsHolder.Size = UDim2.new(0, 0, 1, 0)
	tabButtonsHolder.ZIndex = baseZ + 3
	tabButtonsHolder.Parent = tabScroller

	local tabLayout = Instance.new("UIListLayout")
	tabLayout.FillDirection = Enum.FillDirection.Horizontal
	tabLayout.SortOrder = Enum.SortOrder.LayoutOrder
	tabLayout.VerticalAlignment = Enum.VerticalAlignment.Center
	tabLayout.Padding = UDim.new(0, 4)
	tabLayout.Parent = tabButtonsHolder

	local tabHighlight = Instance.new("Frame")
	tabHighlight.Name = "TabHighlight"
	tabHighlight.BackgroundColor3 = opt.main_color
	tabHighlight.BackgroundTransparency = 0.1
	tabHighlight.BorderSizePixel = 0
	tabHighlight.Size = UDim2.new(0, 0, 0, 3)
	tabHighlight.Position = UDim2.new(0, 0, 1, -3)
	tabHighlight.ZIndex = baseZ + 6
	tabHighlight.Parent = tabSelectionBar
	tabHighlight.Visible = false

	local highlightCorner = Instance.new("UICorner")
	highlightCorner.CornerRadius = UDim.new(0, 2)
	highlightCorner.Parent = tabHighlight

	local tabContainer = Instance.new("Frame")
	tabContainer.Name = "TabContainer"
	tabContainer.BackgroundTransparency = 1
	tabContainer.Position = UDim2.new(0, 12, 0, 78)
	tabContainer.Size = UDim2.new(1, -24, 1, -84)
	tabContainer.ClipsDescendants = true
	tabContainer.ZIndex = baseZ + 1
	tabContainer.Parent = windowFrame

	local resizer = Instance.new("Frame")
	resizer.Name = "Resizer"
	resizer.Active = true
	resizer.BackgroundTransparency = 1
	resizer.BorderSizePixel = 0
	resizer.Position = UDim2.new(1, -18, 1, -18)
	resizer.Size = UDim2.new(0, 18, 0, 18)
	resizer.ZIndex = baseZ + 6
	resizer.Parent = windowFrame

	local resizerIcon = Instance.new("TextLabel")
	resizerIcon.BackgroundTransparency = 1
	resizerIcon.Size = UDim2.new(1, 0, 1, 0)
	resizerIcon.Font = Enum.Font.GothamBold
	resizerIcon.Text = "⋱"
	resizerIcon.TextColor3 = Color3.fromRGB(80, 84, 92)
	resizerIcon.TextSize = 12
	resizerIcon.ZIndex = baseZ + 7
	resizerIcon.Parent = resizer

	do
		local dragging = false
		local dragStart, startPos

		titleBar.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 then
				dragging = true
				dragStart = input.Position
				startPos = windowFrame.Position
				input.Changed:Connect(function()
					if input.UserInputState == Enum.UserInputState.End then
						dragging = false
					end
				end)
			end
		end)

		UserInputService.InputChanged:Connect(function(input)
			if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
				local delta = input.Position - dragStart
				windowFrame.Position = UDim2.new(
					startPos.X.Scale,
					startPos.X.Offset + delta.X,
					startPos.Y.Scale,
					startPos.Y.Offset + delta.Y
				)
			end
		end)
	end

	do
		local resizing = false
		local resizeConn

		resizer.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 and opt.can_resize then
				resizing = true
				input.Changed:Connect(function()
					if input.UserInputState == Enum.UserInputState.End then
						resizing = false
					end
				end)
			end
		end)

		RunService.Heartbeat:Connect(function()
			if resizing then
				local mousePos = getMousePosition()
				local newX = math.max(opt.min_size.X, mousePos.X - windowFrame.AbsolutePosition.X)
				local newY = math.max(opt.min_size.Y, mousePos.Y - windowFrame.AbsolutePosition.Y)
				windowFrame.Size = UDim2.new(0, newX, 0, newY)
			end
		end)
	end

	do
		local collapsed = false
		local canToggle = true
		local savedSize = opt.min_size.Y
		local savedVisibility = {}

		toggleBtn.MouseButton1Click:Connect(function()
			if not canToggle then return end
			canToggle = false

			if not collapsed then
				savedSize = windowFrame.AbsoluteSize.Y
				savedVisibility = {}
				for _, child in ipairs(tabContainer:GetChildren()) do
					savedVisibility[child] = child.Visible
					child.Visible = false
				end
				if tabSelectionBar.Visible then
					savedVisibility[tabSelectionBar] = true
					tabSelectionBar.Visible = false
				end
				resizer.Active = false
				tween(toggleBtn, { Rotation = -90 }, opt.tween_time)
				tween(windowFrame, { Size = UDim2.new(0, windowFrame.AbsoluteSize.X, 0, 36) }, opt.tween_time)
				collapsed = true
			else
				for obj, vis in pairs(savedVisibility) do
					if obj and obj.Parent then
						obj.Visible = vis
					end
				end
				resizer.Active = true
				tween(toggleBtn, { Rotation = 0 }, opt.tween_time)
				tween(windowFrame, { Size = UDim2.new(0, windowFrame.AbsoluteSize.X, 0, savedSize) }, opt.tween_time)
				collapsed = false
			end

			task.delay(opt.tween_time + 0.05, function()
				canToggle = true
			end)
		end)
	end

	local WindowAPI = {}
	local activeTab = nil
	local activeTabButton = nil
	local dropdownOpen = false

	local function updateTabButtonsWidth()
		local totalWidth = 0
		local padding = tabLayout.Padding.Offset or 0
		local count = 0
		for _, btn in ipairs(tabButtonsHolder:GetChildren()) do
			if btn:IsA("TextButton") then
				totalWidth = totalWidth + btn.AbsoluteSize.X
				count = count + 1
			end
		end
		totalWidth = totalWidth + math.max(0, count - 1) * padding
		tabButtonsHolder.Size = UDim2.new(0, totalWidth + 8, 1, 0)
		tabScroller.CanvasSize = UDim2.new(0, totalWidth + 8, 0, 0)
	end

	local function moveHighlight(btn)
		if not btn then
			tabHighlight.Visible = false
			return
		end
		tabHighlight.Visible = true
		local relX = btn.AbsolutePosition.X - tabSelectionBar.AbsolutePosition.X
		tween(tabHighlight, {
			Position = UDim2.new(0, relX, 1, -3),
			Size = UDim2.new(0, btn.AbsoluteSize.X, 0, 3),
		}, 0.2)
	end

	function WindowAPI:AddTab(tabName)
		local TabAPI = {}
		tabName = tostring(tabName or "Tab")

		tabSelectionBar.Visible = true

		local tabBtn = Instance.new("TextButton")
		tabBtn.Name = "Tab_" .. tabName
		tabBtn.BackgroundColor3 = Color3.fromRGB(40, 44, 52)
		tabBtn.BackgroundTransparency = 1
		tabBtn.BorderSizePixel = 0
		tabBtn.Size = UDim2.new(0, 10, 0, 26)
		tabBtn.AutoButtonColor = false
		tabBtn.Font = Enum.Font.GothamSemibold
		tabBtn.Text = tabName
		tabBtn.TextColor3 = Color3.fromRGB(160, 164, 175)
		tabBtn.TextSize = 12
		tabBtn.ZIndex = baseZ + 4
		tabBtn.Parent = tabButtonsHolder

		local btnCorner = Instance.new("UICorner")
		btnCorner.CornerRadius = UDim.new(0, 6)
		btnCorner.Parent = tabBtn

		local btnPadding = Instance.new("UIPadding")
		btnPadding.PaddingLeft = UDim.new(0, 12)
		btnPadding.PaddingRight = UDim.new(0, 12)
		btnPadding.Parent = tabBtn

		task.defer(function()
			tabBtn.Size = UDim2.new(0, tabBtn.TextBounds.X + 28, 0, 26)
			updateTabButtonsWidth()
		end)

		local tabPage = Instance.new("Frame")
		tabPage.Name = "Page_" .. tabName
		tabPage.BackgroundTransparency = 1
		tabPage.Size = UDim2.new(1, 0, 1, 0)
		tabPage.Visible = false
		tabPage.ZIndex = baseZ + 1
		tabPage.Parent = tabContainer

		local pageScroller = Instance.new("ScrollingFrame")
		pageScroller.Name = "Scroller"
		pageScroller.BackgroundTransparency = 1
		pageScroller.BorderSizePixel = 0
		pageScroller.Size = UDim2.new(1, 0, 1, 0)
		pageScroller.CanvasSize = UDim2.new(0, 0, 0, 0)
		pageScroller.ScrollBarThickness = 3
		pageScroller.ScrollBarImageColor3 = opt.main_color
		pageScroller.ScrollBarImageTransparency = 0.3
		pageScroller.ZIndex = baseZ + 1
		pageScroller.AutomaticCanvasSize = Enum.AutomaticSize.Y
		pageScroller.Parent = tabPage

		local pageLayout = Instance.new("UIListLayout")
		pageLayout.SortOrder = Enum.SortOrder.LayoutOrder
		pageLayout.Padding = UDim.new(0, 6)
		pageLayout.Parent = pageScroller

		local pagePadding = Instance.new("UIPadding")
		pagePadding.PaddingTop = UDim.new(0, 4)
		pagePadding.PaddingBottom = UDim.new(0, 8)
		pagePadding.Parent = pageScroller

		local function selectTab()
			if dropdownOpen then return end

			if activeTabButton and activeTabButton ~= tabBtn then
				tween(activeTabButton, { TextColor3 = Color3.fromRGB(160, 164, 175), BackgroundTransparency = 1 }, 0.2)
			end

			for _, page in ipairs(tabContainer:GetChildren()) do
				if page:IsA("Frame") then
					page.Visible = false
				end
			end

			activeTab = tabPage
			activeTabButton = tabBtn

			tween(tabBtn, { TextColor3 = Color3.fromRGB(255, 255, 255), BackgroundTransparency = 0.85 }, 0.2)
			tabPage.Visible = true

			task.defer(function()
				moveHighlight(tabBtn)
			end)
		end

		tabBtn.MouseButton1Click:Connect(selectTab)

		tabBtn.MouseEnter:Connect(function()
			if tabBtn ~= activeTabButton then
				tween(tabBtn, { TextColor3 = Color3.fromRGB(210, 214, 225), BackgroundTransparency = 0.9 }, 0.15)
			end
		end)
		tabBtn.MouseLeave:Connect(function()
			if tabBtn ~= activeTabButton then
				tween(tabBtn, { TextColor3 = Color3.fromRGB(160, 164, 175), BackgroundTransparency = 1 }, 0.15)
			end
		end)

		local tabCount = 0
		for _, child in ipairs(tabButtonsHolder:GetChildren()) do
			if child:IsA("TextButton") then
				tabCount = tabCount + 1
			end
		end
		if tabCount <= 1 then
			task.defer(selectTab)
		end

		function TabAPI:Show()
			selectTab()
		end

		function TabAPI:AddLabel(text)
			text = tostring(text or "Label")
			local label = Instance.new("TextLabel")
			label.Name = "Label"
			label.BackgroundTransparency = 1
			label.Size = UDim2.new(1, -8, 0, 24)
			label.Font = Enum.Font.GothamMedium
			label.Text = text
			label.TextColor3 = Color3.fromRGB(200, 204, 215)
			label.TextSize = 13
			label.TextXAlignment = Enum.TextXAlignment.Left
			label.ZIndex = baseZ + 2
			label.Parent = pageScroller

			local labelPadding = Instance.new("UIPadding")
			labelPadding.PaddingLeft = UDim.new(0, 6)
			labelPadding.Parent = label

			local api = {}
			function api:SetText(newText)
				label.Text = tostring(newText)
			end
			return api, label
		end

		function TabAPI:AddButton(text, callback)
			text = tostring(text or "Button")
			callback = typeof(callback) == "function" and callback or function() end

			local btnFrame = createRoundFrame({
				Color = opt.main_color,
				Transparency = 0.15,
				Size = UDim2.new(1, -8, 0, 32),
				CornerRadius = 6,
			})
			btnFrame.Name = "Button"
			btnFrame.ZIndex = baseZ + 2
			btnFrame.ClipsDescendants = true
			btnFrame.Parent = pageScroller

			createStroke(btnFrame, opt.main_color, 1, 0.5)

			local btn = Instance.new("TextButton")
			btn.Name = "Btn"
			btn.BackgroundTransparency = 1
			btn.Size = UDim2.new(1, 0, 1, 0)
			btn.Font = Enum.Font.GothamSemibold
			btn.Text = text
			btn.TextColor3 = Color3.fromRGB(240, 242, 250)
			btn.TextSize = 13
