				samp.BackgroundColor3=c
				sb.ImageColor3=Color3.fromHSV(h,1,1)
				hexL.Text="#"..string.format("%02X%02X%02X",math.floor(c.R*255),math.floor(c.G*255),math.floor(c.B*255))
				pcall(cb,c)
			end
			upd()
			local pd,sd=false,false
			pal.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then pd=true end end)
			sb.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then sd=true end end)
			conn(UIS.InputChanged,function(i)
				if i.UserInputType==Enum.UserInputType.MouseMovement then
					local mx,my=mpos()
					if pd then
						local rx=math.clamp((mx-pal.AbsolutePosition.X)/pal.AbsoluteSize.X,0,1)
						local ry=math.clamp((my-pal.AbsolutePosition.Y)/pal.AbsoluteSize.Y,0,1)
						h,s=rx,1-ry; pi.Position=UDim2.new(rx,-5,ry,-5); upd()
					elseif sd then
						local ry=math.clamp((my-sb.AbsolutePosition.Y)/sb.AbsoluteSize.Y,0,1)
						v=1-ry; si.Position=UDim2.new(0,-3,ry,-2); upd()
					end
				end
			end)
			conn(UIS.InputEnded,function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then pd=false;sd=false end end)
			local api={}
			function api:Set(c)
				c=typeof(c)=="Color3" and c or Color3.new(1,1,1)
				h,s,v=Color3.toHSV(c)
				pi.Position=UDim2.new(h,-5,1-s,-5); si.Position=UDim2.new(0,-3,1-v,-2); upd()
			end
			function api:Get() return Color3.fromHSV(h,s,v) end
			return api
		end

		function E:AddKeybind(text, cb, ko)
			text=tostring(text or "Keybind")
			cb=type(cb)=="function" and cb or function()end
			ko=type(ko)=="table" and ko or {}
			ko.standard=ko.standard or Enum.KeyCode.F
			local f=baseCard(36)
			newLabel({Text=text,TextColor3=CONFIG.text,TextSize=12,Position=UDim2.new(0,12,0,0),Size=UDim2.new(0.6,0,1,0),ZIndex=Z+5+NL,Parent=f})
			local kb=newBtn({
				BackgroundColor3=CONFIG.surface2,
				Size=UDim2.new(0,76,0,24),Position=UDim2.new(1,-86,0.5,-12),
				TextColor3=CONFIG.text_muted,TextSize=10,
				AutoButtonColor=false,ZIndex=Z+6+NL,Parent=f,
			})
			corner(kb,5); stroke(kb,CONFIG.border,1,0.5)
			local sn={RightControl="RCtrl",LeftControl="LCtrl",LeftShift="LShift",RightShift="RShift",MouseButton1="M1",MouseButton2="M2"}
			local cur=ko.standard
			local function setKD(k) kb.Text=sn[k.Name] or k.Name; cur=k end
			setKD(ko.standard)
			local binding=false
			conn(UIS.InputBegan,function(inp,proc)
				if binding then return end
				if inp.KeyCode==cur and not proc then pcall(cb,cur) end
			end)
			kb.MouseButton1Click:Connect(function()
				if binding then return end
				binding=true; kb.Text="..."; kb.TextColor3=CONFIG.warning
				local i=UIS.InputBegan:Wait()
				if i.KeyCode~=Enum.KeyCode.Unknown then setKD(i.KeyCode) end
				kb.TextColor3=CONFIG.text_muted; binding=false
			end)
			local api={}
			function api:SetKeybind(k) setKD(k) end
			function api:GetKeybind() return cur end
			return api
		end

		function E:AddSeparator()
			local f=newFrame({BackgroundTransparency=1,Size=UDim2.new(1,0,0,10),ZIndex=Z+4+NL,Parent=scroller})
			local l=newFrame({BackgroundColor3=CONFIG.border,BackgroundTransparency=0.4,BorderSizePixel=0,AnchorPoint=Vector2.new(0,0.5),Position=UDim2.new(0,0,0.5,0),Size=UDim2.new(1,0,0,1),ZIndex=Z+5+NL,Parent=f})
			return f
		end

		function E:AddFolder(name)
			name=tostring(name or "Group")
			local outer=newFrame({BackgroundTransparency=1,Size=UDim2.new(1,0,0,36),ZIndex=Z+4+NL,Parent=scroller})
			local hdr=newFrame({BackgroundColor3=CONFIG.surface,BorderSizePixel=0,Size=UDim2.new(1,0,0,36),ZIndex=Z+5+NL,Parent=outer})
			corner(hdr,8); stroke(hdr,opt.accent,1,0.65)
			local ab=newFrame({BackgroundColor3=opt.accent,BorderSizePixel=0,Position=UDim2.new(0,0,0.2,0),Size=UDim2.new(0,3,0.6,0),ZIndex=Z+6+NL,Parent=hdr})
			corner(ab,2)
			local arr=newLabel({Text=">",TextColor3=opt.accent,TextSize=11,Font=Enum.Font.GothamBold,Position=UDim2.new(0,10,0,0),Size=UDim2.new(0,16,1,0),TextXAlignment=Enum.TextXAlignment.Center,ZIndex=Z+6+NL,Parent=hdr})
			newLabel({Text=name,TextColor3=CONFIG.text,TextSize=12,Font=Enum.Font.GothamSemibold,Position=UDim2.new(0,28,0,0),Size=UDim2.new(1,-36,1,0),ZIndex=Z+6+NL,Parent=hdr})
			local cr=newBtn({Size=UDim2.new(1,0,1,0),ZIndex=Z+7+NL,Parent=hdr})
			local body=newFrame({BackgroundTransparency=1,Position=UDim2.new(0,8,0,40),Size=UDim2.new(1,-16,0,0),Visible=false,ZIndex=Z+4+NL,Parent=outer})
			local bl=Instance.new("UIListLayout"); bl.SortOrder=Enum.SortOrder.LayoutOrder; bl.Padding=UDim.new(0,5); bl.Parent=body
			local expanded=false
			local function upd()
				if expanded then body.Size=UDim2.new(1,-16,0,bl.AbsoluteContentSize.Y); outer.Size=UDim2.new(1,0,0,40+bl.AbsoluteContentSize.Y+8) end
			end
			bl:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function() if expanded then upd() end end)
			cr.MouseButton1Click:Connect(function()
				expanded=not expanded
				if expanded then
					tw(arr,{Rotation=90},opt.anim)
					body.Visible=true; upd()
				else
					tw(arr,{Rotation=0},opt.anim)
					body.Visible=false; outer.Size=UDim2.new(1,0,0,36)
				end
			end)
			cr.MouseEnter:Connect(function() tw(hdr,{BackgroundColor3=CONFIG.surface2},0.14) end)
			cr.MouseLeave:Connect(function() tw(hdr,{BackgroundColor3=CONFIG.surface},0.14) end)
			return makeElements(body,NL+1)
		end

		function E:AddHorizontalAlignment()
			local f=newFrame({BackgroundTransparency=1,Size=UDim2.new(1,0,0,36),ZIndex=Z+4+NL,Parent=scroller})
			local hl=Instance.new("UIListLayout"); hl.FillDirection=Enum.FillDirection.Horizontal; hl.SortOrder=Enum.SortOrder.LayoutOrder; hl.Padding=UDim.new(0,6); hl.VerticalAlignment=Enum.VerticalAlignment.Center; hl.Parent=f
			local H={}
			function H:AddButton(t,c)
				t=tostring(t or "Btn"); c=type(c)=="function" and c or function()end
				local bf=newFrame({BackgroundColor3=opt.accent,BackgroundTransparency=0.12,BorderSizePixel=0,Size=UDim2.new(0,10,0,34),ZIndex=Z+5+NL,ClipsDescendants=true,Parent=f})
				corner(bf,7)
				local b=newBtn({Text=t,TextColor3=CONFIG.text,TextSize=11,Size=UDim2.new(1,0,1,0),ZIndex=Z+6+NL,Parent=bf})
				task.defer(function() if b and b.Parent then bf.Size=UDim2.new(0,b.TextBounds.X+24,0,34) end end)
				b.MouseEnter:Connect(function() tw(bf,{BackgroundTransparency=0},0.14) end)
				b.MouseLeave:Connect(function() tw(bf,{BackgroundTransparency=0.12},0.14) end)
				b.MouseButton1Click:Connect(function() ripple(bf,UIS:GetMouseLocation().X,UIS:GetMouseLocation().Y); pcall(c) end)
				return bf
			end
			return H
		end

		return E
	end

	function WindowAPI:AddTab(tabName, iconId)
		tabCount+=1
		tabName=tostring(tabName or "Tab")

		local tbf=newBtn({
			BackgroundColor3=CONFIG.bg3,BackgroundTransparency=1,
			BorderSizePixel=0,
			Size=UDim2.new(1,0,0,34),
			AutoButtonColor=false,
			ZIndex=Z+5,
			Parent=tabScroll,
			Name="Tab_"..tabName,
		})
		corner(tbf,7)

		local indicator=newFrame({BackgroundColor3=opt.accent,BackgroundTransparency=1,BorderSizePixel=0,Position=UDim2.new(0,0,0,5),Size=UDim2.new(0,3,1,-10),ZIndex=Z+6,Parent=tbf})
		corner(indicator,2)

		local iHolder=newFrame({BackgroundColor3=opt.accent,BackgroundTransparency=0.88,BorderSizePixel=0,Position=UDim2.new(0,10,0.5,-10),Size=UDim2.new(0,20,0,20),ZIndex=Z+6,Parent=tbf})
		corner(iHolder,5)
		local iImg=Instance.new("ImageLabel")
		iImg.BackgroundTransparency=1; iImg.Position=UDim2.new(0,3,0,3); iImg.Size=UDim2.new(1,-6,1,-6)
		iImg.Image=iconId or "rbxassetid://10723407389"; iImg.ImageColor3=CONFIG.text_dim
		iImg.ZIndex=Z+7; iImg.Parent=iHolder

		local tLbl=newLabel({Text=tabName,TextColor3=CONFIG.text_dim,TextSize=11,Font=Enum.Font.GothamSemibold,Position=UDim2.new(0,36,0,0),Size=UDim2.new(1,-44,1,0),ZIndex=Z+6,Parent=tbf})

		local page=newFrame({BackgroundTransparency=1,Size=UDim2.new(1,0,1,0),Visible=false,ZIndex=Z+3,Parent=contentArea,Name="Page_"..tabName})
		local scr=Instance.new("ScrollingFrame")
		scr.BackgroundTransparency=1; scr.BorderSizePixel=0
		scr.Size=UDim2.new(1,0,1,0)
		scr.CanvasSize=UDim2.new(0,0,0,0)
		scr.AutomaticCanvasSize=Enum.AutomaticSize.Y
		scr.ScrollBarThickness=2
		scr.ScrollBarImageColor3=opt.accent
		scr.ScrollBarImageTransparency=0.5
		scr.ZIndex=Z+3; scr.Parent=page
		local pl=Instance.new("UIListLayout"); pl.SortOrder=Enum.SortOrder.LayoutOrder; pl.Padding=UDim.new(0,6); pl.Parent=scr
		pad(scr,14,14,14,14)

		local TabAPI=makeElements(scr,0)

		local function select()
			if activeTab and activeTab.btn~=tbf then
				tw(activeTab.btn,{BackgroundTransparency=1},0.2)
				tw(activeTab.ind,{BackgroundTransparency=1},0.2)
				tw(activeTab.icon,{ImageColor3=CONFIG.text_dim},0.2)
				tw(activeTab.iholder,{BackgroundTransparency=0.88},0.2)
				tw(activeTab.lbl,{TextColor3=CONFIG.text_dim},0.2)
				if activeTab.page then activeTab.page.Visible=false end
			end
			activeTab={btn=tbf,ind=indicator,icon=iImg,iholder=iHolder,lbl=tLbl,page=page}
			for _,p in ipairs(contentArea:GetChildren()) do if p:IsA("Frame") then p.Visible=false end end
			tw(tbf,{BackgroundTransparency=0.88},0.2)
			tw(indicator,{BackgroundTransparency=0},0.2)
			tw(iImg,{ImageColor3=opt.accent},0.2)
			tw(iHolder,{BackgroundTransparency=0.75},0.2)
			tw(tLbl,{TextColor3=CONFIG.text},0.2)
			page.Visible=true
			crumbLbl.Text=title.." › "..tabName
		end

		tbf.MouseButton1Click:Connect(select)
		tbf.MouseEnter:Connect(function()
			if activeTab and activeTab.btn==tbf then return end
			tw(tbf,{BackgroundTransparency=0.94},0.14)
			tw(tLbl,{TextColor3=CONFIG.text_muted},0.14)
		end)
		tbf.MouseLeave:Connect(function()
			if activeTab and activeTab.btn==tbf then return end
			tw(tbf,{BackgroundTransparency=1},0.14)
			tw(tLbl,{TextColor3=CONFIG.text_dim},0.14)
		end)

		function TabAPI:Show() select() end

		if tabCount==1 then task.defer(select) end

		return TabAPI
	end

	return WindowAPI
end

return Library
