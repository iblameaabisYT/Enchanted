		tabIndex = tabIndex + 1
		tabName = tostring(tabName or "Tab")

		local tabBtnFrame = Instance.new("TextButton")
		tabBtnFrame.Name = "Tab_" .. tabName
		tabBtnFrame.BackgroundColor3 = Color3.fromRGB(88, 101, 242)
		tabBtnFrame.BackgroundTransparency = 1
		tabBtnFrame.BorderSizePixel = 0
		tabBtnFrame.Size = UDim2.new(1, 0, 0, 38)
		tabBtnFrame.AutoButtonColor = false
		tabBtnFrame.Font = Enum.Font.GothamSemibold
		tabBtnFrame.Text = ""
		tabBtnFrame.ZIndex = baseZ + 4
		tabBtnFrame.Parent = tabHolder
		Utility.createCorner(tabBtnFrame, 9)

		local tabAccent = Instance.new("Frame")
		tabAccent.Name = "Accent"
		tabAccent.BackgroundColor3 = opt.accent
